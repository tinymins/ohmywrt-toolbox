# =============================================================================
# 部署脚本配置文件
# 复制此文件为 .env.deploy 并根据你的环境修改
# =============================================================================

# SSH 服务器地址（可以是 ~/.ssh/config 中的别名或 user@host 格式）
DEPLOY_SERVER="docker.local"

# 本地临时目录（用于存放导出的 Docker 镜像）
DEPLOY_LOCAL_TMP="/tmp"

# 服务器临时目录（用于接收上传的 Docker 镜像）
DEPLOY_REMOTE_TMP="/tmp"

# 服务器部署目录（docker-compose.yml 所在目录）
DEPLOY_REMOTE_DIR="/mnt/docker/apps"

# Docker 镜像文件名
DEPLOY_IMAGE_FILE="rs-fullstack-docker-images.tar"

# 目标服务器上 Rust 服务对外暴露的端口号
# 对应 docker-compose.yml 中 WEB_PORT（宿主机映射端口）
# 默认 8080，如端口已占用可修改为其他空闲端口
DEPLOY_PORT=8080
