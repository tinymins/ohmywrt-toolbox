# ======================================
# Server 环境变量 (本地开发)
# ======================================

# 数据库连接 URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ohmywrt_toolbox_db

# 单一空间模式覆盖 (可选)
# 设置后将覆盖数据库中的设置，并在用户界面完全隐藏此选项
# 可选值: true | false (不设置则使用数据库值)
SINGLE_WORKSPACE_MODE_OVERRIDE=true

# 公网服务器地址（用于生成订阅配置中的 URL）
# 本地开发: http://localhost:4000
# 生产环境: https://your-domain.com
PUBLIC_SERVER_URL=http://localhost:4000

# ======================================
# Clash 代理配置
# ======================================

# Clash API WebSocket URL (用于规则测试)
# 格式: ws://<clash-api-host>:<clash-api-port>
CLASH_WS_URL=ws://10.0.0.1:9999

# Clash API 认证 Token
CLASH_WS_TOKEN=your_clash_token
