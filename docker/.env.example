# ======================================
# 生产环境配置
# ======================================
# 本文件是 docker-compose.yml 使用的环境变量模板
# 首次部署前请复制为同目录下的 .env 并修改：
#   cp docker/.env.example docker/.env
#
# deploy.sh 会自动将 docker/.env 上传到服务器

# ------------------------------------------------------------------------------
# PostgreSQL 数据库
# ------------------------------------------------------------------------------
# 数据库用户名
POSTGRES_USER=postgres

# 数据库密码（生产环境请务必修改！）
POSTGRES_PASSWORD=postgres

# 数据库名
POSTGRES_DB=ohmywrt_toolbox_db

# ------------------------------------------------------------------------------
# 端口配置（宿主机映射端口）
# ------------------------------------------------------------------------------
# 容器内部端口固定不变（Rust server:5678, PostgreSQL:5432）
# 以下仅控制宿主机暴露的端口号，防止与其他服务冲突

# 对外服务端口（浏览器访问此端口）
WEB_PORT=8080

# ------------------------------------------------------------------------------
# 数据目录
# ------------------------------------------------------------------------------
# 容器挂载的数据目录（相对于 docker-compose.yml 所在目录）
# 子目录自动派生：postgres（数据库文件）/ server（上传文件等）
DATA_LOCAL_PATH=data

# ------------------------------------------------------------------------------
# Rust 后端配置
# ------------------------------------------------------------------------------
# 日志级别：trace, debug, info, warn, error
RUST_LOG=info

# ------------------------------------------------------------------------------
# 可选配置
# ------------------------------------------------------------------------------

# 单一工作空间模式覆盖
# 设置后将覆盖数据库中的设置，并在管理后台完全隐藏此选项
# 可选值: true | false（不设置则使用数据库中的值）
# SINGLE_WORKSPACE_MODE_OVERRIDE=true

# ------------------------------------------------------------------------------
# 调试端口暴露（可选）
# ------------------------------------------------------------------------------
# 如需从宿主机直接连接数据库进行调试：
#   docker compose -f docker-compose.yml -f docker-compose.debug.yml up -d
# DB_PORT=5432

# ======================================
# 业务配置（可选）
# ======================================
# 公网服务器地址（用于生成订阅配置中的 URL）
# PUBLIC_SERVER_URL=https://example.com:443

# 配置校验安全：生产环境禁止降级，必须使用 unshare 沙箱隔离
ALLOW_INSECURE_VALIDATION=false
