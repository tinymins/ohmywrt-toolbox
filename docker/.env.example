# ======================================
# Docker Compose 生产环境配置
# ======================================
# 本文件由 docker/docker-compose.yml 读取
# 部署前请复制为 .env 并修改

# PostgreSQL 数据库配置
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=apps_db

# MinIO 对象存储
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=avatars

# 浏览器可直接访问的存储公共 URL（生产环境改为 CDN 或 OSS 公共域名）
STORAGE_PUBLIC_URL=http://localhost:9000

# ======================================
# 端口配置（宿主机映射端口）
# ======================================
# 容器内部端口固定不变（server:4000, web:3000, postgres:5432, redis:6379）
# 以下仅控制宿主机暴露的端口号，防止端口冲突

# 前端端口（宿主机）
WEB_PORT=8080

# ======================================
# 数据目录（容器内所有本地数据的根路径）
# ======================================
# 默认 ./data（相对于 docker-compose.yml 所在目录）
# DATA_LOCAL_PATH=./data

# ======================================
# 调试端口暴露（可选）
# ======================================
# 如需直接访问后端 API 或用数据库工具连接调试：
#   docker compose -f docker-compose.yml -f docker-compose.debug.yml up -d
# DB_PORT=5432
# SERVER_PORT=4000
# REDIS_PORT=6379
