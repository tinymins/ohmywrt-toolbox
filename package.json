{
  "name": "rs-fullstack",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter @acme/web",
    "dev:miniapp": "turbo run dev --filter @acme/miniapp",
    "build": "turbo run build --filter @acme/web",
    "build:miniapp": "turbo run build --filter @acme/miniapp",
    "lint": "biome check .",
    "format": "biome format . --write",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:push": "npx prisma db push --schema prisma/schema.prisma",
    "db:generate": "npx prisma generate --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "prisma": "^7.6.0",
    "turbo": "2.8.17"
  },
  "dependencies": {
    "@prisma/client": "^7.6.0"
  }
}
